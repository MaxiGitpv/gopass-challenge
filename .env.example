# Puerto HTTP del servidor Express
PORT=3000

# Cadena de conexión PostgreSQL para Prisma
DATABASE_URL="postgresql://postgres@localhost:5432/gopass_challenge?schema=public"

# Secreto para firmar y verificar tokens JWT
JWT_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"

# Duración del token (ej. 1d, 8h, 30m)
JWT_EXPIRES_IN="1d"

# Clave de la API de OpenAI — módulo de sugerencias de tareas
OPENAI_API_KEY="sk-..."
